# MongoDB
MONGODB_URI=mongodb://localhost:27017/registerkaro-billing

# Auth
JWT_SECRET=your-jwt-secret-min-32-chars

# Razorpay (test mode keys from dashboard.razorpay.com)
RAZORPAY_KEY_ID=rzp_test_xxxxxxxx
RAZORPAY_KEY_SECRET=your_api_key_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# Email — Ethereal (dev) or Gmail/SendGrid (prod)
EMAIL_HOST=smtp.ethereal.email
EMAIL_PORT=587
EMAIL_USER=your-ethereal-user@ethereal.email
EMAIL_PASS=your-ethereal-password
EMAIL_FROM="BillFlow <billing@registerkaro.in>"
